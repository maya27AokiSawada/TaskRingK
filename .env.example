# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Read at build time by app/build.gradle.kts into BuildConfig (porting_spec §12-10).

# Sentry DSN. Leave empty to disable Sentry (the app still starts).
SENTRY_DSN=

# Sentry environment name. Defaults: dev flavor -> development, prod flavor -> production.
SENTRY_ENVIRONMENT=
