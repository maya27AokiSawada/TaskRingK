# Kotlin版 .gitignore

# Secrets — never commit
.env

# Gradle files
.gradle/
.kotlin/
build/
**/build/

# Local configuration file (sdk path, etc)
local.properties

# Android Studio
*.iml
.idea/
.vscode/
.DS_Store
*.log
.externalNativeBuild
.cxx

# Keystore files
*.jks
*.keystore
key.properties

# Firebase
google-services.json
firebase_options.kt

# Signing
release/
*.aab
*.apk

# Kotlin
*.class
*.jar
*.kotlin_module

# Keep the Gradle wrapper jar (required to build after clone)
!gradle/wrapper/gradle-wrapper.jar

# NDK
obj/

# Captures folder for screenshots
captures/

# IntelliJ
out/

# User-specific configurations
.gradletasknamecache

# Flutter reference docs are local/reference-only for this Kotlin port
docs/Flutter_Version_docs/
docs/Flutter_version_docs/
docs/flutter_version_docs/
# Exception: divergence spec is an original document for Kotlin/Swift implementation
!docs/Flutter_Version_docs/specifications/divergence_spec_from_flutter.md
